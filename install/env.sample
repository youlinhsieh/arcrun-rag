# arcrun-rag 包 credential 清單（key 名＋用途；值由安裝現場填，絕不進版控）
# 血統：polaris/mira/.env 的 key 名盤點（只列產品包需要的子集；leo 個人 key 不進包）。
# 生產（客戶 CF 帳號）：走 `acr creds push`（CF Secrets 機制，rag-wave1 design §5/§8）。
# 本機 demo（miniflare）：無 credential 解密鏈 → 需要 key 的 workflow 由呼叫端注入（已知限制）。

# ── 必填（裝包時 installer 自動產生/取得）─────────────────────────────
# 租戶 namespace（self-hosted 明碼分區標籤，非密碼）
NAMESPACE=demo
# Gitea（知識 repo 真相源）：installer 自建本機容器時自動產生 token
GITEA_BASE_URL=http://127.0.0.1:3300
GITEA_TOKEN=
# Console 管理員（首次開 /console 會引導設定；也可預先填）
CONSOLE_ADMIN_EMAIL=
CONSOLE_ADMIN_PASSWORD=

# ── 選配：LLM 精耕（rag_wiki_digest；沒填＝精耕不啟用，ingest/查詢不受影響）──
# Google AI Studio API key（預設 provider＝Gemini；換源＝換 recipe 不換引擎）
GEMINI_API_KEY=
# 自動精耕接鏈（G11，預設 true）：文件 ingest 完自動跑 Gemini 精耕長 wiki 頁。
# ⚠ 成本：每檔一次 Gemini API 呼叫＝token 花費；文件量大的客戶設 false 改手動/批次觸發。
# 沒填 GEMINI_API_KEY 時此開關自動視為 false（installer 誠實告知）。
AUTO_DIGEST=true

# ── 選配：通知（notify_owner；沒填＝不啟用）────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 雲端版（客戶自己 CF 帳號部署）才需要；本機 demo 不用 ──────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
ENCRYPTION_KEY=
MCP_OWNER_SECRET=
MCP_STATIC_TOKEN=
